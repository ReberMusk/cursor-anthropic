# Copy to .env and adjust. Node 20.6+ loads it natively:
#   node --env-file=.env src/server.js
# or: export $(grep -v '^#' .env | xargs) && npm start

# ───────── Server ─────────
PORT=8787

# ───────── Storage ─────────
# Backend driver: sqlite (default, zero-config) | mysql
DB_DRIVER=sqlite
# -- sqlite: file location (created on first run)
DATABASE_PATH=./data/cursor-anthropic.db
# -- mysql: either a single URL ...
# DATABASE_URL=mysql://cursor:cursor_pw@127.0.0.1:3306/cursor_anthropic
# ... or discrete parts (used when DATABASE_URL is unset)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=cursor
DB_PASSWORD=cursor_pw
DB_NAME=cursor_anthropic
DB_POOL=10
# docker-compose only: MySQL root password.
# Note: by default the compose stack does NOT publish MySQL/Redis ports to the
# host (the app talks to them over the internal network), so there is nothing
# to clash with a local MySQL/Redis. To connect from the host for debugging,
# add a `ports:` mapping to the relevant service in docker-compose.yml.
DB_ROOT_PASSWORD=root_pw

# ───────── Cache (optional) ─────────
# Set to enable a shared Redis cache for the hot read paths (settings, API keys).
# Without it, an in-process memory cache is used (fine for a single instance).
# REDIS_URL=redis://127.0.0.1:6379

# ───────── Admin ─────────
# Seeded into the admins table on first run if the table is empty.
# If ADMIN_PASSWORD is omitted, a random one is generated and printed to stdout.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-login
# Secret used to sign admin session JWTs. Set a long random value in production;
# if unset, a per-process random secret is used (sessions reset on restart).
JWT_SECRET=

# ───────── Outbound API auth (sk-...) ─────────
# Optional single shared key. Leave blank to manage keys in the admin UI instead.
# If neither this nor any DB key exists, /v1/messages is OPEN (local testing only).
GATEWAY_API_KEY=

# ───────── Cursor protocol ─────────
# Force a specific Cursor model for ALL requests (overrides per-request mapping).
# Set to a model your accounts can use in their region, e.g. claude-4-sonnet.
CURSOR_MODEL=
# Cursor client version sent in headers (bump if Cursor upgrades and rejects requests)
CURSOR_CLIENT_VERSION=3.1.0

# ───────── Proxy (fallback) ─────────
# Global outbound proxy used when an account has no proxy_url / proxy pool bound.
# Supports socks5://, socks4://, http://, https://  (h2-over-proxy keeps HTTP/2).
ALL_PROXY=
# HTTPS_PROXY=

# ───────── Debug ─────────
# CURSOR_PROTOBUF_DEBUG=1
# CURSOR_FRAME_DEBUG=1
